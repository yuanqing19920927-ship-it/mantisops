server:
  http_addr: "127.0.0.1:3100"
  grpc_addr: "0.0.0.0:3101"
  grpc_advertise_addr: "192.168.1.100:3101"
  grpc_tls_addr: "0.0.0.0:3102"
  grpc_tls_cert: ""
  grpc_tls_key: ""
  psk_token: "your-secure-psk-token"

victoria_metrics:
  url: "http://127.0.0.1:8428"

sqlite:
  path: "./data/opsboard.db"

probe:
  interval: 30
  timeout: 5

websocket:
  ping_interval: 15

auth:
  username: "admin"
  password: "change-me"
  jwt_secret: "change-me-to-a-random-string-at-least-32-chars"

aliyun:
  enabled: false
  access_key_id: ""
  access_key_secret: ""
  interval: 60
  instances: []

encryption_key: "generate-with-openssl-rand-hex-32"
